# Use the Transaction Pooler (works over IPv4 — most home/office networks don't support IPv6).
# Found in Supabase: Connect button → Direct tab → switch "Connection Method" to "Transaction pooler"
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-publishable-key>
SUPABASE_DB_HOST=aws-0-us-west-1.pooler.supabase.com
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.<your-project-ref>
SUPABASE_DB_PASSWORD=<your-db-password>
SUPABASE_DB_PORT=6543
